ENVIRONMENT=development
PORT=3333
VERSION=1
BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5000
SECRET=<troque_por_um_segredo_forte>
MAILHOG_PORT=7081
SMTP_HOST=mail
SMTP_PORT=1025
SMTP_SECURE=no
PGADMIN_ROOT_USER=super.secret@pgadmin4.com
PGADMIN_PASSWORD=<troque_por_senha_forte>
