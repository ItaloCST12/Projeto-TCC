MERCADO_PAGO_WEBHOOK_SECRET=<secret_de_assinatura_do_webhook>
MERCADO_PAGO_API_BASE=https://api.mercadopago.com
PIX_CONCILIACAO_ATIVA=true
PIX_CONCILIACAO_INTERVAL_MS=60000
