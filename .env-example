#Prisma Configuration
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${HOST}:${PGPORT}/meta?schema=public

# PIX (Mercado Pago)
MERCADO_PAGO_ACCESS_TOKEN=<APP_USR_ou_TEST_do_mercado_pago>
