generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  nome                 String?
  id                   Int                   @id @default(autoincrement())
  email                String                @unique
  telefone             String?
  password             String
  role                 String                @default("USER")
  enderecos            Endereco[]
  pedidos              Pedido[]
  atendimentoMensagens AtendimentoMensagem[]
  resetTokens          PasswordResetToken[]
  notificacoes         Notificacao[]
  pushSubscriptions    PushSubscription[]
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  usuarioId Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  usuario   Usuario   @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId, expiresAt])
}

model Endereco {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  rua       String
  numero    String?
  cidade    String
  cep       String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  pedidos   Pedido[]
}

model Produto {
  id                  Int                   @id @default(autoincrement())
  nome                String
  preco               Decimal               @default(0) @db.Decimal(10, 2)
  precoAbacaxiGrande  Decimal?              @db.Decimal(10, 2)
  precoAbacaxiMedio   Decimal?              @db.Decimal(10, 2)
  precoAbacaxiPequeno Decimal?              @db.Decimal(10, 2)
  estoque             Int                   @default(0)
  disponivel          Boolean               @default(true)
  excluido            Boolean               @default(false)
  imagemUrl           String?
  pedidos             Pedido[]
  itemPedidos         ItemPedido[]
  movimentacoes       MovimentacaoEstoque[]
}

model Pedido {
  id             Int                   @id @default(autoincrement())
  createdAt      DateTime              @default(now())
  usuarioId      Int
  produtoId      Int
  enderecoId     Int?
  quantidade     Int
  unidade        String
  tipoEntrega    String
  formaPagamento String                @default("DINHEIRO")
  valorTotal     Decimal               @default(0) @db.Decimal(10, 2)
  status         String                @default("PENDENTE")
  usuario        Usuario               @relation(fields: [usuarioId], references: [id])
  produto        Produto               @relation(fields: [produtoId], references: [id])
  endereco       Endereco?             @relation(fields: [enderecoId], references: [id])
  items          ItemPedido[]
  movimentacoes  MovimentacaoEstoque[]
  notificacoes   Notificacao[]
}

model MovimentacaoEstoque {
  id         Int      @id @default(autoincrement())
  produtoId  Int
  tipo       String
  quantidade Int
  motivo     String?
  pedidoId   Int?
  createdAt  DateTime @default(now())
  produto    Produto  @relation(fields: [produtoId], references: [id])
  pedido     Pedido?  @relation(fields: [pedidoId], references: [id])

  @@index([produtoId, createdAt])
  @@index([tipo])
}

model Notificacao {
  id          Int      @id @default(autoincrement())
  usuarioId   Int?
  pedidoId    Int?
  destinoRole String
  tipo        String
  titulo      String
  mensagem    String
  lida        Boolean  @default(false)
  createdAt   DateTime @default(now())
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  pedido      Pedido?  @relation(fields: [pedidoId], references: [id])

  @@index([destinoRole, lida, createdAt])
  @@index([usuarioId, lida, createdAt])
  @@index([pedidoId])
}

model PushSubscription {
  id             Int      @id @default(autoincrement())
  usuarioId      Int
  destinoRole    String
  endpoint       String   @unique
  p256dh         String
  auth           String
  expirationTime BigInt?
  ativa          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, ativa])
  @@index([destinoRole, ativa])
}

model ItemPedido {
  id             Int     @id @default(autoincrement())
  pedidoId       Int
  produtoId      Int
  quantidade     Int
  unidade        String  @default("unidade")
  valorUnitario  Decimal @default(0) @db.Decimal(10, 2)
  valorTotalItem Decimal @default(0) @db.Decimal(10, 2)
  pedido         Pedido  @relation(fields: [pedidoId], references: [id])
  produto        Produto @relation(fields: [produtoId], references: [id])
}

model AtendimentoMensagem {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  autor     String
  texto     String
  createdAt DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
}
