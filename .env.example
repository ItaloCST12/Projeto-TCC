# ---- Banco de dados (obrigatório) ----
DATABASE_URL=postgresql://usuario:senha@host:5432/banco?schema=public

# ---- Autenticação JWT (obrigatório em produção) ----
JWT_SECRET=troque-por-uma-string-segura

# ---- Servidor ----
PORT=3333
NODE_ENV=production

# ---- CORS (URL do frontend, separar por vírgula se necessário) ----
CORS_ORIGIN=https://seu-app.onrender.com

# ---- Resend - recuperação de senha (opcional em dev, obrigatório em prod) ----
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM="Projeto TCC <noreply@seudominio.com>"
APP_NAME=Projeto TCC

# ---- Docker local (não necessário em produção) ----
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=secret
# DB_NAME=meta
# PGPORT=55432
# PGADMIN_PORT=5050
# PGADMIN_ROOT_USER=admin@admin.com
# PGADMIN_PASSWORD=admin
