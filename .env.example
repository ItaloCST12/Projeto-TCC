# ---- Banco de dados (obrigatório) ----
DATABASE_URL=postgresql://usuario:senha@host:5432/banco?schema=public

# ---- Autenticação JWT (obrigatório em produção) ----
JWT_SECRET=troque-por-uma-string-segura

# ---- Servidor ----
PORT=3333
NODE_ENV=production

# ---- CORS (URL do frontend, separar por vírgula se necessário) ----
CORS_ORIGIN=https://seu-app.onrender.com

# ---- Resend - recuperação de senha (opcional em dev, obrigatório em prod) ----
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM="Projeto TCC <noreply@seudominio.com>"
APP_NAME=Projeto TCC

# ---- Cloudinary (uploads em nuvem) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Opcional: pasta base para organização das mídias
CLOUDINARY_FOLDER=projeto-tcc/produtos

# ---- Rate limit - recuperação de senha ----
# Máximo de solicitações de código por janela (chave: IP + e-mail)
FORGOT_PASSWORD_MAX_REQUESTS=5
# Janela de tempo, em minutos
FORGOT_PASSWORD_WINDOW_MINUTES=15

# ---- Web Push (notificação do sistema fora do site) ----
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BCIjs6Kc_PjHe5wuAkdvsLOW-sbz34wSB-9-v1n7OngHxyKw-loZFB9FmuN3wZSXFUdVJAVi0ouaWN0L9bce8GE
VAPID_PRIVATE_KEY=1zUgLXxgbuIAZXd3LdAicQ0UKqbGT7VvwWGejqAPlxk
VAPID_SUBJECT=admin@example.com

